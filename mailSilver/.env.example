# 复制为 .env 并按需修改；该文件入库作为模板，.env 自身被 .gitignore 忽略

# Webhook 投递密钥（POST /api/email 校验 x-webhook-secret 头部）
EMAIL_SECRET=change-email

# 监听端口（默认 23879）
# PORT=23879

# SQLite 数据库路径（默认 ./data/mail.db）
# DB_PATH=./data/mail.db

# 静态资源目录（默认 ./public，前端 vite build 会写到这里）
# PUBLIC_DIR=./public
# SPA_INDEX=./public/index.html

# 单封邮件最大字节数（默认 25MB）
# MAX_RAW_BYTES=26214400

# 用户邮箱固定后缀（默认 @kt.sb）
# MAIL_DOMAIN=@kt.sb

# 会话有效期（毫秒，默认 30 天）
# SESSION_TTL_MS=2592000000

# Cookie 安全标志，HTTPS 部署建议显式置 true（默认根据 NODE_ENV 推断）
# COOKIE_SECURE=true

# 会话 Cookie 名（默认 mail_session）
# COOKIE_NAME=mail_session
# ADMIN_PREFIX=admin